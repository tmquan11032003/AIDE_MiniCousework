# Image tags for the lakehouse stack.
# Start with floating tags to get it pulled; pin to digests after first successful pull.
SPARK_ICEBERG_IMAGE=tabulario/spark-iceberg:latest
ICEBERG_REST_IMAGE=apache/iceberg-rest-fixture:latest
MINIO_IMAGE=minio/minio:latest
MC_IMAGE=minio/mc:latest

# Object-store credentials (local only, not secret).
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1

# Host directory for persistent Docker volumes (on the big /home partition, not /).
# Change this per machine if needed.
HOST_DATA_DIR=/home/mq-ubuntu/data/coffee-lakehouse
